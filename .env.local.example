# Set to "true" to use the local filesystem for storage instead of Supabase.
# All blobs will be written to .blob-store/ in the project root.
# Remove this (or set to "false") when deploying — use the Supabase vars below instead.
USE_LOCAL_BLOB=true
CURRENT_REP_ID=
CURRENT_REP_NAME=

# Required in production (when USE_LOCAL_BLOB is not set).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=
